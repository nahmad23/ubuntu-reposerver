# =============================================================================
# Ubuntu reposerver configuration
# =============================================================================
# This file is sourced by every script (and by install.sh). Edit it to match
# your environment, then re-run install.sh / repoctl as needed.
# All values are plain shell; arrays use (parentheses).
# -----------------------------------------------------------------------------

# --- System layout ----------------------------------------------------------
# Dedicated, unprivileged user that owns the mirror and runs the timers.
APTLY_USER="aptly"
# Home directory of that user. Holds the GPG keyring and aptly config.
APTLY_HOME="/srv/aptly"
# aptly rootDir. The published, web-served tree lives in ${APTLY_ROOT}/public.
APTLY_ROOT="${APTLY_HOME}/data"

# --- What to mirror ----------------------------------------------------------
# Ubuntu releases (codenames) to mirror.
RELEASES=(noble jammy)
# Components within each suite.
COMPONENTS=(main restricted universe multiverse)
# Architectures to mirror. amd64 covers most x86_64 servers; add arm64 if needed.
ARCHES=(amd64)
# Mirror the -backports pocket too? Patches do not require it; off by default.
INCLUDE_BACKPORTS="false"

# Upstream mirror URLs. Point ARCHIVE_URL at a geographically close mirror
# (e.g. http://<country>.archive.ubuntu.com/ubuntu) to speed up the initial sync.
ARCHIVE_URL="http://archive.ubuntu.com/ubuntu"
SECURITY_URL="http://security.ubuntu.com/ubuntu"

# --- Staged promotion channels ----------------------------------------------
# Order matters: snapshots flow left -> right. The first stage is the one the
# nightly job publishes to automatically; later stages are promoted manually.
STAGES=(dev test prod)

# How many snapshots to retain per suite before cleanup drops the oldest.
SNAPSHOT_KEEP="6"

# --- Signing -----------------------------------------------------------------
GPG_KEY_NAME="Ubuntu Reposerver Signing Key"
GPG_KEY_EMAIL="reposerver@example.com"

# --- Client-facing -----------------------------------------------------------
# Hostname clients use to reach this server. Used only when generating example
# client configuration; the server itself does not depend on it.
REPOSERVER_HOST="reposerver.example.com"
