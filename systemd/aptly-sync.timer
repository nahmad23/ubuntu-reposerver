[Unit]
Description=Run the Ubuntu reposerver sync nightly
Documentation=https://github.com/nahmad23/ubuntu-reposerver

[Timer]
# Nightly at 02:00 local time, with jitter to avoid hammering upstream mirrors.
OnCalendar=*-*-* 02:00:00
RandomizedDelaySec=1800
Persistent=true

[Install]
WantedBy=timers.target
